{
  "name": "mana-chess-desktop",
  "version": "0.2.0",
  "private": true,
  "productName": "Mana Chess",
  "description": "Mana Chess desktop build for real-time chess with mana, cooldowns, bots, private matches, and local cosmetics.",
  "author": {
    "name": "Diesel337"
  },
  "license": "UNLICENSED",
  "homepage": "https://mana-chess-production.up.railway.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Diesel337/Mana-chess.git"
  },
  "main": "src/main.cjs",
  "scripts": {
    "check": "node scripts/check-syntax.cjs",
    "build-info": "node scripts/write-build-info.cjs",
    "start": "electron .",
    "pack:win": "node scripts/write-build-info.cjs && node scripts/run-electron-builder.cjs --dir --win --x64",
    "dist:win": "node scripts/write-build-info.cjs && node scripts/run-electron-builder.cjs --win nsis --x64",
    "smoke:win": "node scripts/smoke-win-app.cjs",
    "smoke:win:steam": "node scripts/smoke-win-app.cjs --mode=windowed --steam-env",
    "smoke:win:modes": "node scripts/smoke-win-app.cjs --all-modes",
    "smoke:win:installer": "node scripts/smoke-win-installer.cjs",
    "smoke:win:offline": "node scripts/smoke-win-offline.cjs",
    "smoke:win:deep-link": "node scripts/smoke-win-deep-link.cjs",
    "smoke:win:bridge": "node scripts/smoke-win-bridge.cjs",
    "smoke:win:reconnect": "node scripts/smoke-win-reconnect.cjs",
    "smoke:win:second-instance": "node scripts/smoke-win-second-instance.cjs",
    "verify:win": "node scripts/verify-win-build.cjs",
    "verify:win:signatures": "node scripts/verify-win-signatures.cjs",
    "verify:win:installer": "node scripts/verify-win-installer.cjs",
    "verify:steam-session": "node scripts/verify-steam-session.cjs",
    "steam:verify": "node scripts/prepare-steam-build.cjs --verify --app-id=111111 --depot-id=111112",
    "steam:prepare:preview": "node scripts/prepare-steam-build.cjs",
    "steam:prepare:upload": "node scripts/prepare-steam-build.cjs --upload",
    "steam:preview": "node scripts/run-steam-build.cjs",
    "steam:upload": "node scripts/run-steam-build.cjs --upload",
    "release:win:preflight": "node scripts/release-preflight-win.cjs"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.diesel337.manachess",
    "productName": "Mana Chess",
    "executableName": "Mana Chess",
    "copyright": "Copyright (C) 2026 Diesel337",
    "artifactName": "Mana Chess Setup ${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/steamworks.js/dist/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "publisherName": "Diesel337"
      },
      "target": [
        "nsis"
      ]
    },
    "protocols": [
      {
        "name": "Mana Chess",
        "schemes": [
          "manachess"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "shortcutName": "Mana Chess",
      "uninstallDisplayName": "Mana Chess"
    }
  },
  "dependencies": {
    "steamworks.js": "0.4.0"
  }
}
