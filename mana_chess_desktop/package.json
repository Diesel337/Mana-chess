{
  "name": "mana-chess-desktop",
  "version": "0.2.0",
  "private": true,
  "productName": "Mana Chess",
  "description": "Mana Chess desktop build for real-time chess with mana, cooldowns, bots, private matches, and local cosmetics.",
  "author": {
    "name": "Diesel337"
  },
  "license": "UNLICENSED",
  "homepage": "https://mana-chess-production.up.railway.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Diesel337/Mana-chess.git"
  },
  "main": "src/main.cjs",
  "scripts": {
    "check": "node --check src/main.cjs && node --check src/preload.cjs",
    "build-info": "node scripts/write-build-info.cjs",
    "start": "electron .",
    "pack:win": "node scripts/write-build-info.cjs && electron-builder --dir --win --x64",
    "dist:win": "node scripts/write-build-info.cjs && electron-builder --win nsis --x64",
    "smoke:win": "node scripts/smoke-win-app.cjs",
    "smoke:win:modes": "node scripts/smoke-win-app.cjs --all-modes",
    "verify:win": "node scripts/verify-win-build.cjs"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.diesel337.manachess",
    "productName": "Mana Chess",
    "executableName": "Mana Chess",
    "copyright": "Copyright (C) 2026 Diesel337",
    "artifactName": "Mana Chess Setup ${version}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "signtoolOptions": {
        "publisherName": "Diesel337"
      },
      "target": [
        "nsis"
      ]
    },
    "protocols": [
      {
        "name": "Mana Chess",
        "schemes": [
          "manachess"
        ]
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Mana Chess",
      "uninstallDisplayName": "Mana Chess"
    }
  }
}
