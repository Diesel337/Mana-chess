<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <script>
      (() => {
        const bridge = window.ManaChessDesktop;
        const info = typeof bridge?.getInfo === "function" ? bridge.getInfo() : null;
        if (new URLSearchParams(window.location.search).get("desktop") === "1" || info?.isDesktop) {
          document.documentElement.dataset.desktop = "true";
          if (info?.channel) document.documentElement.dataset.desktopChannel = info.channel;
          if (info?.version) document.documentElement.dataset.desktopVersion = info.version;
        }
      })();
    </script>

    <script>
      (() => {
        const jumpSelector = '[phx-click="start_practice"], [phx-click="start_tutorial"], [phx-click="sit_anywhere"], [phx-click="create_private"], [phx-click="leave"], [phx-click="sit"]';
        let pendingJump = false;
        const toTop = () => {
          window.requestAnimationFrame(() => window.scrollTo(0, 0));
          window.setTimeout(() => window.scrollTo(0, 0), 90);
          window.setTimeout(() => window.scrollTo(0, 0), 300);
        };

        document.addEventListener("click", event => {
          if (!event.target.closest(jumpSelector)) return;
          pendingJump = true;
          toTop();
        }, true);

        new MutationObserver(() => {
          if (!pendingJump || !document.querySelector(".mc-play-area, .mc-menu")) return;
          pendingJump = false;
          toTop();
        }).observe(document.documentElement, {childList: true, subtree: true});
      })();
    </script>

    <.live_title default="Mana Chess">{assigns[:page_title]}</.live_title>

    <meta
      name="description"
      content="Mana Chess: ajedrez en tiempo real con elixir, cooldown, cosmeticos locales y partidas privadas por link."
    /> <meta name="theme-color" content="#0b120e" />
    <meta name="application-name" content="Mana Chess" />
    <meta name="apple-mobile-web-app-title" content="Mana Chess" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-TileColor" content="#0b120e" />
    <meta property="og:site_name" content="Mana Chess" />
    <meta property="og:title" content="Mana Chess" />
    <meta
      property="og:description"
      content="Ajedrez en tiempo real con elixir, cooldown, cosmeticos locales y partidas privadas por link."
    /> <meta property="og:type" content="website" />
