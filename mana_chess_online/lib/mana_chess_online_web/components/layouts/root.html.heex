        }
        .mc-game:has(.mc-play-area)>.mc-match-status p,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-match-status p{
          grid-column:1;
          max-width:100%;
          margin:0;
          font-size:.78rem;
          line-height:1.25;
        }
