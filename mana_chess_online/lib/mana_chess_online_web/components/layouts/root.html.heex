<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <script>
      (() => {
        const bridge = window.ManaChessDesktop;
        const info = typeof bridge?.getInfo === "function" ? bridge.getInfo() : null;
        if (new URLSearchParams(window.location.search).get("desktop") === "1" || info?.isDesktop) {
          document.documentElement.dataset.desktop = "true";
          if (info?.channel) document.documentElement.dataset.desktopChannel = info.channel;
          if (info?.version) document.documentElement.dataset.desktopVersion = info.version;
        }
      })();
    </script>

    <script>
      (() => {
        const jumpSelector = '[phx-click="start_practice"], [phx-click="start_tutorial"], [phx-click="sit_anywhere"], [phx-click="create_private"], [phx-click="leave"], [phx-click="sit"]';
        let pendingJump = false;
        const toTop = () => {
          window.requestAnimationFrame(() => window.scrollTo(0, 0));
          window.setTimeout(() => window.scrollTo(0, 0), 90);
          window.setTimeout(() => window.scrollTo(0, 0), 300);
        };

        document.addEventListener("click", event => {
          if (!event.target.closest(jumpSelector)) return;
          pendingJump = true;
          toTop();
        }, true);

        new MutationObserver(() => {
          if (!pendingJump || !document.querySelector(".mc-play-area, .mc-menu")) return;
          pendingJump = false;
          toTop();
        }).observe(document.documentElement, {childList: true, subtree: true});
      })();
    </script>

    <.live_title default="Mana Chess">{assigns[:page_title]}</.live_title>

    <meta
      name="description"
      content="Mana Chess: ajedrez en tiempo real con elixir, cooldown, cosmeticos locales y partidas privadas por link."
    /> <meta name="theme-color" content="#0b120e" />
    <meta name="application-name" content="Mana Chess" />
    <meta name="apple-mobile-web-app-title" content="Mana Chess" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-TileColor" content="#0b120e" />
    <meta property="og:site_name" content="Mana Chess" />
    <meta property="og:title" content="Mana Chess" />
    <meta
      property="og:description"
      content="Ajedrez en tiempo real con elixir, cooldown, cosmeticos locales y partidas privadas por link."
    /> <meta property="og:type" content="website" />
    <meta property="og:url" content="https://mana-chess-production.up.railway.app/" />
    <meta
      property="og:image"
      content="https://mana-chess-production.up.railway.app/images/logo.svg"
    /> <meta property="og:image:alt" content="Logo de Mana Chess" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Mana Chess" />
    <meta
      name="twitter:description"
      content="Ajedrez en tiempo real con elixir, cooldown, cosmeticos locales y partidas privadas por link."
    />
    <meta
      name="twitter:image"
      content="https://mana-chess-production.up.railway.app/images/logo.svg"
    /> <meta name="twitter:image:alt" content="Logo de Mana Chess" />
    <link rel="canonical" href="https://mana-chess-production.up.railway.app/" />
    <link rel="icon" href={~p"/images/logo.svg"} type="image/svg+xml" />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <link
      phx-track-static
      rel="stylesheet"
      href={~p"/assets/css/app.css?v=cosmetics-pack-preview-20260703b"}
    />
    <link
      phx-track-static
      rel="stylesheet"
      href={~p"/assets/css/layout.css?v=layout-module-20260706"}
    />
    <script
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/cosmetics.js?v=cosmetics-module-20260706"}
    >
    </script>

    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix.js?v=play-feedback-fit14-20260617"}
    >
    </script>

    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/phoenix_live_view.js?v=play-feedback-fit14-20260617"}
    >
    </script>

    <script
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/local_stats.js?v=local-stats-module-20260706"}
    >
    </script>

    <script
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/sound.js?v=sound-module-20260706"}
    >
    </script>

    <script
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/chat.js?v=chat-module-20260706"}
    >
    </script>

    <script
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/app.js?v=chat-module-20260706"}
    >
    </script>

    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>

  <body>{@inner_content}</body>
</html>
