          overflow:auto;
          scrollbar-width:thin;
        }
        html[data-desktop="true"] .mc-game:has(.mc-play-area){
          grid-template-columns:var(--mc-game-rail) var(--mc-game-board);
          column-gap:var(--mc-game-gap);
          justify-content:center;
        }
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-play-area{
          grid-column:2;
          grid-row:3 / span 12;
        }
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-practice-banner,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-tutorial,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-spectator-banner,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-reconnect-banner,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-match-status,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-seats,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-feedback-zone,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-final-panel,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-promotion,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-check-message,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-actions{
          max-width:var(--mc-game-rail);
          grid-column:1;
        }
        .mc-game:has(.mc-play-area)>.mc-match-status,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-match-status{
          min-height:0;
          grid-template-columns:minmax(0,1fr);
          align-items:start;
          gap:7px;
          padding:10px 12px 12px 16px;
        }
        .mc-game:has(.mc-play-area)>.mc-match-status div,
        html[data-desktop="true"] .mc-game:has(.mc-play-area)>.mc-match-status div{
          min-width:0;
          gap:3px;
