    <link rel="icon" href={~p"/images/logo.svg"} type="image/svg+xml" />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css?v=feed-polish-fit24-20260618"} />
    <style>
      .mc-cosmetic-groups{display:grid;gap:8px}.mc-cosmetic-group{display:grid;gap:8px}.mc-menu .mc-cosmetic-groups{grid-template-columns:minmax(0,1fr);gap:8px}.mc-menu .mc-cosmetic-group{grid-template-columns:82px minmax(0,1fr);align-items:center;gap:8px}.mc-menu .mc-cosmetic-group-label{display:flex;align-items:center;min-width:0;padding-left:2px;line-height:1.1}.mc-menu .mc-skin-options{grid-template-columns:repeat(3,minmax(128px,1fr));gap:8px}.mc-menu .mc-skin-option{min-height:44px;padding:6px 8px}.mc-menu .mc-skin-option strong{overflow:visible;text-overflow:clip;white-space:normal}.mc-skin-preview-classic,.mc-skin-dot-classic{--skin-frame:#f7f2e8;--skin-light:#f3eee2;--skin-dark:#171817}.mc-piece-skin-preview{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));place-items:center;width:46px;aspect-ratio:1;gap:2px;padding:4px;overflow:hidden;border:2px solid var(--piece-frame,#e6bd68);border-radius:7px;background:radial-gradient(circle at 30% 20%,rgba(255,243,207,.14),transparent 42%),#08100b;box-shadow:0 8px 16px rgba(0,0,0,.22)}.mc-piece-skin-preview-runes .mc-piece-sample-white{background:radial-gradient(circle at 31% 23%,#fff 0 24%,#ddfff0 38%,#8bd9bd 68%,#2f7f67 100%);color:#03251d;box-shadow:inset 0 0 0 2px rgba(139,217,189,.78),0 0 14px rgba(139,217,189,.42)}.mc-piece-skin-preview-crystal .mc-piece-sample-white{background:radial-gradient(circle at 32% 22%,#fff 0 24%,#f8f2ff 39%,#c7d2ff 67%,#6d8fff 100%);color:#101629;box-shadow:inset 0 0 0 2px rgba(255,240,182,.72),0 0 16px rgba(109,143,255,.46)}.mc-menu .mc-piece-skin-preview{width:26px;padding:2px;border-radius:5px}.mc-skin-locked{border-style:dashed;filter:saturate(.72);opacity:.74}.mc-skin-unlocked{filter:none;opacity:1}.mc-skin-locked[data-cosmetic-premium]:not(.mc-skin-unlocked){box-shadow:inset 0 0 0 1px rgba(255,217,130,.1)}.mc-play-area>.mc-piece-strip{right:auto!important;left:6px!important}.mc-board-stack[data-board-skin="classic"]{background:linear-gradient(135deg,rgba(247,242,232,.14),transparent 30%),linear-gradient(225deg,rgba(0,0,0,.22),transparent 42%),#121713;border-color:rgba(247,242,232,.26)}.mc-board-stack[data-board-skin="classic"] .mc-light{background:#f3eee2}.mc-board-stack[data-board-skin="classic"] .mc-dark{background:#171817}.mc-board-stack[data-board-skin="gilded"]{background:linear-gradient(135deg,rgba(255,240,182,.28),transparent 32%),linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.018)),#211408;border-color:rgba(255,240,182,.62)}.mc-board-stack[data-board-skin="gilded"] .mc-light{background:#f4d477}.mc-board-stack[data-board-skin="gilded"] .mc-dark{background:#6e3b1f}.mc-shell.mc-piece-skin-runes .mc-board .mc-white{background:radial-gradient(circle at 31% 23%,#fff 0 25%,#ddfff0 40%,#8bd9bd 68%,#2f7f67 100%);color:#03251d;box-shadow:inset 0 1px rgba(255,255,255,.48),inset 0 0 0 3px rgba(139,217,189,.46),inset 0 -11px 18px rgba(8,58,45,.2),0 0 16px rgba(139,217,189,.42),0 9px 12px rgba(0,0,0,.32);text-shadow:0 1px rgba(255,255,255,.62),0 0 10px rgba(139,217,189,.48)}.mc-shell.mc-piece-skin-runes .mc-board .mc-black{background:radial-gradient(circle at 35% 24%,#3b2670,#140d28 62%,#030207 100%);color:#c7b3ff;text-shadow:0 0 16px rgba(168,132,255,.58),0 0 4px rgba(139,217,189,.32)}.mc-shell.mc-piece-skin-crystal .mc-board .mc-white{background:radial-gradient(circle at 32% 22%,#fff 0 25%,#f8f2ff 40%,#c7d2ff 67%,#6d8fff 100%);color:#101629;box-shadow:inset 0 1px rgba(255,255,255,.55),inset 0 0 0 3px rgba(255,240,182,.46),inset 0 -11px 18px rgba(50,69,148,.22),0 0 18px rgba(109,143,255,.48),0 9px 12px rgba(0,0,0,.32);text-shadow:0 1px rgba(255,255,255,.68),0 0 10px rgba(109,143,255,.5)}.mc-shell.mc-piece-skin-crystal .mc-board .mc-black{background:radial-gradient(circle at 35% 24%,#283d80,#101623 66%,#05070d 100%);color:#fff0b6;text-shadow:0 0 15px rgba(255,240,182,.52),0 0 5px rgba(109,143,255,.34)}@media (max-width:480px){.mc-menu .mc-cosmetic-group{grid-template-columns:minmax(0,1fr);align-items:stretch;gap:4px}.mc-menu .mc-skin-options{grid-template-columns:repeat(3,minmax(0,1fr));gap:5px}.mc-menu .mc-piece-skin-preview{width:20px}.mc-menu .mc-skin-preview{width:20px}.mc-menu .mc-skin-option{grid-template-columns:auto;justify-items:center;min-height:34px;padding:5px 3px;text-align:center}.mc-menu .mc-skin-option strong{font-size:.62rem}}@media (min-width:1760px){.mc-shell:has(.mc-menu) .mc-menu{--mc-shop-rail:min(380px,calc((100vw - 1180px)/2 - 32px));grid-template-columns:var(--mc-shop-rail) minmax(0,1fr);column-gap:16px;row-gap:14px;margin-left:calc(0px - var(--mc-shop-rail) - 16px)}.mc-shell:has(.mc-menu) .mc-menu>:not(.mc-skins){grid-column:2}.mc-shell:has(.mc-menu) .mc-skins{grid-column:1;grid-row:2/span 4;align-self:start;gap:12px;padding:12px}.mc-shell:has(.mc-menu) .mc-skins-head{display:flex}.mc-shell:has(.mc-menu) .mc-skin-option small{display:block}.mc-shell:has(.mc-menu) .mc-cosmetic-groups{gap:12px}.mc-shell:has(.mc-menu) .mc-cosmetic-group{grid-template-columns:minmax(0,1fr);align-items:stretch;gap:8px}.mc-shell:has(.mc-menu) .mc-skin-options{grid-template-columns:minmax(0,1fr);gap:8px}.mc-shell:has(.mc-menu) .mc-skin-option{grid-template-columns:auto minmax(0,1fr);justify-items:stretch;min-height:52px;padding:8px 10px;text-align:left}.mc-shell:has(.mc-menu) .mc-skin-preview,.mc-shell:has(.mc-menu) .mc-piece-skin-preview{width:34px}.mc-shell:has(.mc-menu) .mc-skin-option strong{font-size:.82rem}}
      .mc-skins-rail{display:none}@media (min-width:1280px){.mc-shell:has(.mc-menu){grid-template-columns:minmax(220px,280px) minmax(0,1fr) 240px;gap:16px;width:min(1500px,calc(100vw - 32px));align-items:start}.mc-shell:has(.mc-menu)>.mc-game{grid-column:2}.mc-shell:has(.mc-menu)>.mc-panel{grid-column:3}.mc-shell:has(.mc-menu) .mc-menu{grid-template-columns:minmax(0,1fr);margin-left:0;column-gap:initial;row-gap:14px}.mc-shell:has(.mc-menu) .mc-menu>:not(.mc-skins){grid-column:auto}.mc-shell:has(.mc-menu) .mc-skins-inline{display:none}.mc-shell:has(.mc-menu)>.mc-skins-rail{display:grid;grid-column:1;grid-row:1;align-self:start;position:sticky;top:24px;gap:12px;padding:12px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skins-head{display:flex}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skin-option small{display:block;grid-column:1/-1;font-size:.62rem;line-height:1.1;white-space:normal}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-cosmetic-groups{gap:12px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-cosmetic-group{grid-template-columns:minmax(0,1fr);align-items:stretch;gap:8px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skin-options{grid-template-columns:repeat(2,minmax(0,1fr))!important;gap:6px!important}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skin-option{grid-template-columns:auto minmax(0,1fr);justify-items:stretch;min-height:46px;padding:7px;text-align:left}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skin-preview,.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-piece-skin-preview{width:28px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-skin-option strong{overflow:visible;font-size:.74rem;text-overflow:clip;white-space:normal}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-palette-unlock{min-height:44px;padding:7px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-palette-preview{width:28px}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-palette-presets button{min-height:26px;font-size:.68rem}.mc-shell:has(.mc-menu)>.mc-skins-rail .mc-palette-fields input{height:24px}}
      .mc-skin-preview-custom,.mc-skin-dot-custom{--skin-frame:var(--mc-custom-board-frame,#fff0b6);--skin-light:var(--mc-custom-board-light,#d9c58f);--skin-dark:var(--mc-custom-board-dark,#243a31)}.mc-piece-skin-preview-custom,.mc-piece-dot-custom{--piece-frame:var(--mc-custom-board-frame,#fff0b6);--piece-a:var(--mc-custom-piece-white,#f6f1df);--piece-b:var(--mc-custom-piece-black,#241745)}.mc-palette-editor{display:grid;gap:7px;min-width:0}.mc-palette-unlock{display:grid;grid-template-columns:auto minmax(0,1fr);grid-template-rows:auto auto;align-items:center;gap:2px 9px;min-height:50px;padding:8px 10px;border:1px dashed rgba(255,255,255,.12);border-radius:8px;background:linear-gradient(180deg,rgba(255,255,255,.055),rgba(255,255,255,.018)),#111b13;color:var(--mc-cream);text-align:left}.mc-palette-unlock strong{overflow:hidden;font-size:.82rem;line-height:1.1;text-overflow:ellipsis;white-space:nowrap}.mc-palette-unlock small{color:var(--mc-muted);font-size:.68rem}.mc-palette-preview{grid-row:1/span 2;display:grid;grid-template-columns:repeat(2,1fr);width:34px;aspect-ratio:1;overflow:hidden;border:2px solid var(--mc-custom-board-frame,#fff0b6);border-radius:7px}.mc-palette-preview i:nth-child(1){background:var(--mc-custom-board-light,#d9c58f)}.mc-palette-preview i:nth-child(2){background:var(--mc-custom-board-dark,#243a31)}.mc-palette-preview i:nth-child(3){background:var(--mc-custom-piece-white,#f6f1df)}.mc-palette-preview i:nth-child(4){background:var(--mc-custom-piece-black,#241745)}.mc-palette-presets,.mc-palette-fields{display:grid;gap:6px}.mc-palette-presets{grid-template-columns:repeat(3,minmax(0,1fr))}.mc-palette-fields{grid-template-columns:repeat(2,minmax(0,1fr))}.mc-palette-presets button{min-height:30px;padding:0 6px;border:1px solid rgba(255,255,255,.08);border-radius:7px;background:#101912;color:var(--mc-cream);font-size:.72rem;font-weight:900}.mc-palette-fields label{display:grid;gap:4px;min-width:0;color:var(--mc-muted);font-size:.68rem;font-weight:900}.mc-palette-fields input{width:100%;height:28px;min-width:0;padding:2px;border:1px solid rgba(255,255,255,.1);border-radius:7px;background:#08100b}.mc-board-stack[data-board-skin="custom"] .mc-light{background:linear-gradient(135deg,rgba(255,255,255,.22),transparent 45%),var(--mc-custom-board-light,#d9c58f)}.mc-board-stack[data-board-skin="custom"] .mc-dark{background:radial-gradient(circle at 70% 22%,color-mix(in srgb,var(--mc-custom-board-light,#d9c58f) 20%,transparent),transparent 52%),var(--mc-custom-board-dark,#243a31)}html[data-piece-skin="custom"] .mc-game:has(.mc-play-area) .mc-white,.mc-shell.mc-piece-skin-custom .mc-game:has(.mc-play-area) .mc-white,html[data-piece-skin="custom"] .mc-drag-ghost.mc-white{background:radial-gradient(circle at 31% 23%,#fff 0 22%,var(--mc-custom-piece-white,#f6f1df) 62%,color-mix(in srgb,var(--mc-custom-piece-white,#f6f1df) 58%,#000) 100%);color:var(--mc-custom-piece-white-text,#10140f)}html[data-piece-skin="custom"] .mc-game:has(.mc-play-area) .mc-black,.mc-shell.mc-piece-skin-custom .mc-game:has(.mc-play-area) .mc-black,html[data-piece-skin="custom"] .mc-drag-ghost.mc-black{background:radial-gradient(circle at 35% 24%,color-mix(in srgb,var(--mc-custom-piece-black,#241745) 78%,#fff),var(--mc-custom-piece-black,#241745) 64%,#050407 100%);color:var(--mc-custom-piece-black-text,#fff8dc)}
    </style>
    <script>
      (() => {
        const boardKey = "mana-chess-board-skin";
        const pieceKey = "mana-chess-piece-skin";
        const unlockKey = "mana-chess-cosmetic-unlocks";
        const paletteKey = "mana-chess-custom-palette";
        const boards = ["classic", "gilded", "arcane", "custom"];
        const pieces = ["classic", "runes", "crystal", "custom"];
        const included = new Set(["board:classic", "board:gilded", "piece:classic", "piece:runes"]);
        const defaultPalette = {
          boardLight: "#d9c58f",
          boardDark: "#243a31",
          pieceWhite: "#f6f1df",
          pieceBlack: "#241745"
        };
        const palettePresets = {
          midnight: {boardLight: "#8bd9bd", boardDark: "#241745", pieceWhite: "#f5fff9", pieceBlack: "#2c1c58"},
          emerald: {boardLight: "#c7e6a1", boardDark: "#1f4938", pieceWhite: "#f5f1d6", pieceBlack: "#12352b"},
          frost: {boardLight: "#c7d2ff", boardDark: "#172033", pieceWhite: "#f8f2ff", pieceBlack: "#283d80"}
        };
        const unlockId = (kind, skin) => `${kind}:${skin}`;
        const readUnlocks = () => {
          try {
            return new Set(JSON.parse(localStorage.getItem(unlockKey) || "[]"));
          } catch (_error) {
            return new Set();
          }
        };
        const isPaletteUnlocked = () => {
          const unlocks = readUnlocks();
          return unlocks.has("palette:custom") || unlocks.has("board:custom") || unlocks.has("piece:custom");
        };
        const isUnlocked = (kind, skin) => {
          if (skin === "custom") return isPaletteUnlocked();
          return included.has(unlockId(kind, skin)) || readUnlocks().has(unlockId(kind, skin));
        };
        const unlock = (kind, skin) => {
          if (isUnlocked(kind, skin)) return;
          const unlocks = readUnlocks();
          if (skin === "custom" || kind === "palette") {
            unlocks.add("palette:custom");
            unlocks.add("board:custom");
            unlocks.add("piece:custom");
          } else {
            unlocks.add(unlockId(kind, skin));
          }
          try {
            localStorage.setItem(unlockKey, JSON.stringify([...unlocks]));
          } catch (_error) {}
        };
        const validHex = (value) => /^#[0-9a-f]{6}$/i.test(value || "");
        const normalizePalette = (palette = {}) => {
          const next = {...defaultPalette};
          Object.keys(next).forEach((key) => {
            if (validHex(palette[key])) next[key] = palette[key];
          });
          return next;
        };
        const readPalette = () => {
          try {
            return normalizePalette(JSON.parse(localStorage.getItem(paletteKey) || "{}"));
          } catch (_error) {
            return {...defaultPalette};
          }
        };
        const writePalette = (palette) => {
          try {
            localStorage.setItem(paletteKey, JSON.stringify(normalizePalette(palette)));
          } catch (_error) {}
        };
        const hexToRgb = (hex) => {
          const value = hex.replace("#", "");
          return {
            r: parseInt(value.slice(0, 2), 16),
            g: parseInt(value.slice(2, 4), 16),
            b: parseInt(value.slice(4, 6), 16)
          };
        };
        const contrastFor = (hex) => {
          const {r, g, b} = hexToRgb(hex);
          const luminance = (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255;
          return luminance > 0.58 ? "#10140f" : "#fff8dc";
        };
        const glowFor = (hex, alpha) => {
          const {r, g, b} = hexToRgb(hex);
          return `rgba(${r}, ${g}, ${b}, ${alpha})`;
        };
        const applyPalette = () => {
          const palette = readPalette();
          const style = document.documentElement.style;
          style.setProperty("--mc-custom-board-light", palette.boardLight);
          style.setProperty("--mc-custom-board-dark", palette.boardDark);
          style.setProperty("--mc-custom-board-frame", palette.boardLight);
          style.setProperty("--mc-custom-piece-white", palette.pieceWhite);
          style.setProperty("--mc-custom-piece-white-text", contrastFor(palette.pieceWhite));
          style.setProperty("--mc-custom-piece-black", palette.pieceBlack);
          style.setProperty("--mc-custom-piece-black-text", contrastFor(palette.pieceBlack));
          style.setProperty("--mc-custom-piece-white-glow", glowFor(palette.pieceWhite, ".42"));
          style.setProperty("--mc-custom-piece-black-glow", glowFor(palette.pieceBlack, ".46"));
          const unlocked = isPaletteUnlocked();
          document.querySelectorAll("[data-palette-color]").forEach((input) => {
            input.value = palette[input.dataset.paletteColor] || defaultPalette[input.dataset.paletteColor];
            input.disabled = !unlocked;
          });
          document.querySelectorAll("[data-palette-editor]").forEach((editor) => {
            editor.classList.toggle("is-locked", !unlocked);
            editor.classList.toggle("is-unlocked", unlocked);
          });
          document.querySelectorAll("[data-palette-unlock]").forEach((button) => {
            button.classList.toggle("mc-skin-locked", !unlocked);
            button.classList.toggle("mc-skin-unlocked", unlocked);
            button.setAttribute("aria-disabled", unlocked ? "false" : "true");
          });
          document.querySelectorAll("[data-palette-status]").forEach((status) => {
            status.textContent = unlocked ? "Local activo" : "Premium pronto";
          });
        };
        const read = (key, fallback, valid) => {
          try {
            const value = localStorage.getItem(key);
            return valid.includes(value) ? value : fallback;
          } catch (_error) {
            return fallback;
          }
        };
        const write = (key, value, valid) => {
          if (!valid.includes(value)) return;
          try {
            localStorage.setItem(key, value);
          } catch (_error) {}
        };
        const render = () => {
          const storedBoard = read(boardKey, "classic", boards);
          const storedPiece = read(pieceKey, "classic", pieces);
          const board = isUnlocked("board", storedBoard) ? storedBoard : "classic";
          const piece = isUnlocked("piece", storedPiece) ? storedPiece : "classic";
          if (board !== storedBoard) write(boardKey, board, boards);
          if (piece !== storedPiece) write(pieceKey, piece, pieces);
          applyPalette();
          document.documentElement.dataset.boardSkin = board;
          document.documentElement.dataset.pieceSkin = piece;
          document.querySelectorAll(".mc-board-stack").forEach((stack) => stack.dataset.boardSkin = board);
          document.querySelectorAll(".mc-shell").forEach((shell) => {
            shell.dataset.pieceSkin = piece;
            shell.classList.toggle("mc-piece-skin-classic", piece === "classic");
            shell.classList.toggle("mc-piece-skin-runes", piece === "runes");
            shell.classList.toggle("mc-piece-skin-crystal", piece === "crystal");
            shell.classList.toggle("mc-piece-skin-custom", piece === "custom");
          });
          document.querySelectorAll("[data-board-skin-choice]").forEach((button) => {
            const skin = button.dataset.boardSkinChoice;
            const unlocked = isUnlocked("board", skin);
            const selected = skin === board && unlocked;
            button.classList.toggle("mc-skin-selected", selected);
            button.classList.toggle("mc-skin-locked", !unlocked);
            button.classList.toggle("mc-skin-unlocked", unlocked && !included.has(unlockId("board", skin)));
            button.setAttribute("aria-disabled", unlocked ? "false" : "true");
            button.setAttribute("aria-pressed", selected ? "true" : "false");
            button.querySelectorAll("[data-cosmetic-status]").forEach((status) => {
              status.textContent = unlocked ? "Local activo" : "Premium pronto";
            });
          });
          document.querySelectorAll("[data-piece-skin-choice]").forEach((button) => {
            const skin = button.dataset.pieceSkinChoice;
            const unlocked = isUnlocked("piece", skin);
            const selected = skin === piece && unlocked;
            button.classList.toggle("mc-skin-selected", selected);
            button.classList.toggle("mc-skin-locked", !unlocked);
            button.classList.toggle("mc-skin-unlocked", unlocked && !included.has(unlockId("piece", skin)));
            button.setAttribute("aria-disabled", unlocked ? "false" : "true");
            button.setAttribute("aria-pressed", selected ? "true" : "false");
            button.querySelectorAll("[data-cosmetic-status]").forEach((status) => {
              status.textContent = unlocked ? "Local activo" : "Premium pronto";
            });
          });
        };
        window.ManaChessCosmetics = {
          chooseBoard: (skin) => {
            unlock("board", skin);
            write(boardKey, skin, boards);
            render();
          },
          choosePiece: (skin) => {
            unlock("piece", skin);
            write(pieceKey, skin, pieces);
            render();
          },
          choosePalette: (preset) => {
            unlock("palette", "custom");
            if (palettePresets[preset]) writePalette(palettePresets[preset]);
            write(boardKey, "custom", boards);
            write(pieceKey, "custom", pieces);
            render();
          },
          setPaletteColor: (key, value) => {
            if (!validHex(value) || !Object.prototype.hasOwnProperty.call(defaultPalette, key)) return;
            unlock("palette", "custom");
            const palette = readPalette();
            palette[key] = value;
            writePalette(palette);
            if (key.startsWith("board")) write(boardKey, "custom", boards);
            if (key.startsWith("piece")) write(pieceKey, "custom", pieces);
            render();
          },
          render
        };
        document.addEventListener("click", (event) => {
          const palettePreset = event.target.closest("[data-palette-preset]");
          if (palettePreset) {
            event.preventDefault();
            window.ManaChessCosmetics.choosePalette(palettePreset.dataset.palettePreset);
            return;
          }
          const paletteUnlock = event.target.closest("[data-palette-unlock]");
          if (paletteUnlock) {
            event.preventDefault();
            window.ManaChessCosmetics.choosePalette();
            return;
          }
          const piece = event.target.closest("[data-piece-skin-choice]");
          if (piece && !piece.disabled) {
            event.preventDefault();
            window.ManaChessCosmetics.choosePiece(piece.dataset.pieceSkinChoice);
            return;
          }
          const board = event.target.closest("[data-board-skin-choice]");
          if (board && !board.disabled) {
            event.preventDefault();
            window.ManaChessCosmetics.chooseBoard(board.dataset.boardSkinChoice);
          }
        }, true);
        document.addEventListener("input", (event) => {
          const input = event.target.closest("[data-palette-color]");
          if (!input || input.disabled) return;
          window.ManaChessCosmetics.setPaletteColor(input.dataset.paletteColor, input.value);
        }, true);
        document.addEventListener("DOMContentLoaded", render, {once: true});
        document.addEventListener("phx:page-loading-stop", render);
        let queued = false;
        new MutationObserver(() => {
          if (queued) return;
          queued = true;
          requestAnimationFrame(() => {
            queued = false;
            render();
          });
        }).observe(document.documentElement, {childList: true, subtree: true});
      })();
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix.js?v=play-feedback-fit14-20260617"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix_live_view.js?v=play-feedback-fit14-20260617"}></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js?v=sound-control-fit23-20260618"}></script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
